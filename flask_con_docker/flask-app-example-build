pipeline {
	agent any
	stages {
		stage ("clone repository da git"){
			steps {
			    sh "rm -rf formazione_sou_k8s"
				checkout scm
				sh "cd formazione_sou_k8s/flask_con_docker"
			}
		}

		stage ("push su dockerhub"){
			steps {
			whitCredentials([usernamePassword(
                credentialsId: 'dockerhub_credentials_id',
            	usernameVariable:'USERNAME_DOCKERHUB',
            	passwordVariable:'PASSWORD_DOCKERHUB'
            	)]){
			    sh "echo -n $PASSWORD_DOCKERHUB | docker login -u $USERNAME_DOCKERHUB --password-stdin"
				sh "docker build -t $USERNAME_DOCKERHUB/formazione_sou_k8s:latest ."
				sh "docker push $USERNAME_DOCKERHUB/formazione_sou_k8s:latest"
				sh "docker logout"
			}
		}
	}
}
}